  "typography": {
    "font-family-base":   "'Inter', 'Segoe UI', sans-serif",
    "font-family-mono":   "'JetBrains Mono', 'Fira Code', monospace",
    "font-size-base":     "13px",
    "font-size-sm":       "11px",
    "font-size-lg":       "15px",
    "font-weight-normal": "400",
    "font-weight-bold":   "600",
    "line-height":        "1.5"
  },
  "layout": {
    "header-height":      "60px",
    "border-radius-sm":   "4px",
    "border-radius-md":   "6px",
    "border-radius-pill": "999px",
    "row-height":         "28px",
    "table-padding-x":    "8px",
    "table-padding-y":    "4px",
    "container-max-width":"1400px",
    "sidebar-width":      "220px"
  },
  "logo": {
    "text":               "HLSTATSX: CE",
    "color":              "#58d9f0",
    "icon-bg":            "#1f6feb",
    "show-icon":          true
  },
  "header": {
    "show-social-icons": true,
    "nav-buttons": [
      { "label": "Contents", "url": "/",        "color": "#d4a017", "text-color": "#000" },
      { "label": "Search",   "url": "/search",  "color": "#2ea043", "text-color": "#fff" },
      { "label": "Forums",   "url": "#",        "color": "#d4a017", "text-color": "#000" },
      { "label": "Help",     "url": "/help",    "color": "#d4a017", "text-color": "#000" }
    ]
  },
  "charts": {
    "style":     "dark",
    "map-tiles": "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
  }
