{
  "meta": {
    "slug": "hlstatsx-dark",
    "name": "HLStatsX Dark",
    "description": "Thème sombre original fidèlement reproduit",
    "author": "HLStatsX Team",
    "version": "1.0.0",
    "preview": "preview.png"
  },
  "colors": {
    "bg-body":            "#0d1117",
    "bg-header":          "#0a0f1a",
    "bg-surface":         "#111827",
    "bg-surface-alt":     "#161b22",
    "bg-row-even":        "#0f1623",
    "bg-row-odd":         "#131c2e",
    "bg-nav-tab":         "#1f2937",
    "bg-nav-tab-active":  "#1f6feb",
    "border":             "#1e293b",
    "text-primary":       "#c9d1d9",
    "text-secondary":     "#8b949e",
    "text-heading":       "#e6edf3",
    "link":               "#58a6ff",
    "link-hover":         "#79b8ff",
    "accent-primary":     "#1f6feb",
    "accent-secondary":   "#58d9f0",
    "btn-gold-bg":        "#d4a017",
    "btn-gold-text":      "#000000",
    "btn-green-bg":       "#2ea043",
    "btn-green-text":     "#ffffff",
    "activity-high":      "#3fb950",
    "activity-mid":       "#d29922",
